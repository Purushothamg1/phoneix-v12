# ── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/phoneix_db

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=8h

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── WhatsApp / Meta Business API (optional) ───────────────────
# Set meta_api_enabled to '1' in Settings to activate Cloud API mode.
# When enabled, WhatsApp messages are sent via Meta Cloud API automatically.
# When disabled (default), the UI opens wa.me with pre-filled text instead.
# META_WABA_ID=
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=
# META_WEBHOOK_VERIFY_TOKEN=
